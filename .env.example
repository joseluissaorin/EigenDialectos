# EigenDialectos Environment Variables
# Copy to .env and fill in values

# Twitter/X Academic API (for corpus collection)
TWITTER_BEARER_TOKEN=

# Hugging Face (for model downloads)
HF_TOKEN=

# Weights & Biases (for experiment tracking)
WANDB_API_KEY=
WANDB_PROJECT=eigendialectos

# Data paths (override defaults)
# DATA_DIR=./data
# MODEL_DIR=./models
# OUTPUT_DIR=./outputs

# Device (auto, cpu, cuda, mps)
# DEVICE=auto
